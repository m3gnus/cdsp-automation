// Merge these settings into the existing `general = { ... };` block.
// The trailing space after the command is required: Shairport Sync appends
// the AirPlay dB value (-30..0, with -144 meaning mute).
general =
{
    ignore_volume_control = "yes";
    run_this_when_volume_is_set = "/usr/bin/python3 /usr/local/libexec/airplay_volume_bridge.py --notify ";
};

// AirPlay interrupts the installation schedule while its stream is active.
sessioncontrol =
{
    run_this_before_play_begins = "/usr/bin/python3 /usr/local/libexec/airplay_volume_bridge.py --airplay-start";
    run_this_after_play_ends = "/usr/bin/python3 /usr/local/libexec/airplay_volume_bridge.py --airplay-stop";
    wait_for_completion = "yes";
};
