+#[derive(Clone, Copy, Debug, PartialEq, Eq)]
+struct VolumeSyncCommand {
+    id: u64,
+    volume: u16,
+}
+
+fn start_volume_sync_socket(path: PathBuf) -> Option<mpsc::Receiver<VolumeSyncCommand>> {
+    use std::os::unix::fs::PermissionsExt;
+
+    if let Err(e) = std::fs::remove_file(&path)
+        && e.kind() != std::io::ErrorKind::NotFound
+    {
+        warn!(
+            "Could not remove stale volume sync socket {}: {e}",
+            path.display()
+        );
+        return None;
+    }
+    let socket = match UnixDatagram::bind(&path) {
+        Ok(socket) => socket,
+        Err(e) => {
+            warn!("Could not bind volume sync socket {}: {e}", path.display());
+            return None;
+        }
+    };
+    if let Err(e) = std::fs::set_permissions(&path, std::fs::Permissions::from_mode(0o660)) {
+        warn!("Could not set volume sync socket permissions: {e}");
+    }
+    let (sender, receiver) = mpsc::channel(16);
+    tokio::spawn(async move {
+        let mut buffer = [0_u8; 64];
+        loop {
+            match socket.recv(&mut buffer).await {
+                Ok(size) => {
+                    let command = std::str::from_utf8(&buffer[..size])
+                        .ok()
+                        .and_then(|value| value.trim().split_once(':'))
+                        .and_then(|(id, volume)| {
+                            Some(VolumeSyncCommand {
+                                id: id.parse().ok()?,
+                                volume: volume.parse().ok()?,
+                            })
+                        });
+                    match command {
+                        Some(command) => match sender.try_send(command) {
+                            Ok(()) => (),
+                            Err(mpsc::error::TrySendError::Full(_)) => {
+                                warn!("Volume sync command queue is full")
+                            }
+                            Err(mpsc::error::TrySendError::Closed(_)) => break,
+                        },
+                        None => warn!("Ignoring invalid volume sync command"),
+                    }
+                }
+                Err(e) => {
+                    warn!("Volume sync socket failed: {e}");
+                    break;
+                }
+            }
+        }
+    });
+    info!("Listening for volume sync commands on {}", path.display());
+    Some(receiver)
+}
+
+async fn send_volume_sync_ack(path: &Path, command: VolumeSyncCommand) -> std::io::Result<()> {
+    let socket = UnixDatagram::unbound()?;
+    let payload = format!("spotify_ack:{}:{}", command.id, command.volume);
+    socket.send_to(payload.as_bytes(), path).await?;
+    Ok(())
+}
